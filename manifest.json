{
  "manifest_version": 3,
  "name": "Volume Booster",
  "version": "1.0.0",
  "description": "Boost system and browser audio volume up to 250%",
  "permissions": ["activeTab"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "public/popup.html",
    "default_icon": {
      "16": "src/icons/icon-16.png",
      "48": "src/icons/icon-48.png",
      "128": "src/icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-scripts/audio-enhancer.js"],
      "css": ["content-scripts/audio.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content-scripts/*", "public/*"],
      "matches": ["<all_urls>"]
    }
  ]
}