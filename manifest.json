{
  "manifest_version": 3,
  "name": "Volume Boost",
  "version": "1.0.0",
  "description": "Boost the audio volume on the current tab.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://*/*", "http://*/*"],
  "action": {
    "default_title": "Volume Boost",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
